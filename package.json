{
  "name": "@agent-pattern-labs/wordlines",
  "version": "0.1.0",
  "description": "Purpose-scoped timelines for human and AI work.",
  "type": "module",
  "main": "./dist/wordline.js",
  "types": "./dist/wordline.d.ts",
  "exports": {
    ".": {
      "types": "./dist/wordline.d.ts",
      "import": "./dist/wordline.js"
    }
  },
  "bin": {
    "wordlines": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "smoke": "npm run build && node dist/cli.js --help",
    "test": "npm run build && node scripts/smoke-test.mjs"
  },
  "files": [
    "dist",
    "docs",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai-agents",
    "local-first",
    "timeline",
    "productivity",
    "workflow",
    "cli"
  ],
  "author": "Charlie Greenman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agent-Pattern-Labs/wordlines.git"
  },
  "bugs": {
    "url": "https://github.com/Agent-Pattern-Labs/wordlines/issues"
  },
  "homepage": "https://github.com/Agent-Pattern-Labs/wordlines#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
