{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordlines.dev/schemas/wordline.schema.json",
  "title": "Wordline",
  "type": "object",
  "required": ["version", "id", "title", "intent", "created_at", "updated_at", "status", "events", "checkpoints"],
  "properties": {
    "version": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "completed", "archived"]
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkpoint"
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": ["id", "type", "created_at"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["note", "link", "file", "screenshot", "decision", "question", "checkpoint", "agent_run", "artifact"]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        },
        "stored_path": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        },
        "size_bytes": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "checkpoint": {
      "type": "object",
      "required": ["id", "created_at", "title"],
      "properties": {
        "id": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "event_count": {
          "type": "number"
        }
      },
      "additionalProperties": true
    }
  }
}
